{
    "name": "tallersmart/yii3-app",
    "description": "Sistema de Gestión de Talleres Mecánicos - TallerSmart con Yii3",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-pdo": "*",
        "firebase/php-jwt": "^7.0",
        "yiisoft/active-record": "^1.0",
        "yiisoft/app": "dev-master",
        "yiisoft/cache-file": "^3.0",
        "yiisoft/config": "^1.0",
        "yiisoft/db-migration": "^2.0",
        "yiisoft/db-mysql": "^2.0",
        "yiisoft/di": "^1.0",
        "yiisoft/event-dispatcher": "^1.0",
        "yiisoft/factory": "^1.0",
        "yiisoft/http": "^1.2",
        "yiisoft/json": "^1.0",
        "yiisoft/log": "^2.0",
        "yiisoft/log-target-file": "^2.0",
        "yiisoft/middleware-dispatcher": "^5.0",
        "yiisoft/router-fastroute": "^4.0",
        "yiisoft/security": "^1.0",
        "yiisoft/session": "^3.0.1",
        "yiisoft/translator": "^3.0",
        "yiisoft/validator": "^2.0",
        "yiisoft/yii-console": "^2.4",
        "yiisoft/yii-view-renderer": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/config": true,
            "yiisoft/injector": true
        }
    }
}
