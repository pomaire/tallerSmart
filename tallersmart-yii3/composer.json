{
    "name": "tallersmart/yii3-app",
    "description": "Sistema de Gestión de Talleres Mecánicos - TallerSmart con Yii3",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "yiisoft/yii-app": "dev-master",
        "yiisoft/db-mysql": "^2.0",
        "yiisoft/active-record": "^1.0",
        "yiisoft/router-fastroute": "^3.0",
        "yiisoft/middleware-dispatcher": "^5.0",
        "yiisoft/hydra": "^2.0",
        "yiisoft/http": "^1.2",
        "yiisoft/json": "^1.0",
        "firebase/php-jwt": "^6.10",
        "ext-json": "*",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/injector": true
        }
    }
}
