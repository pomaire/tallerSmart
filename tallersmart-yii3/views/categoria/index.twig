{% extends "@app/views/layouts/main.twig" %}

{% block title %}Categorías - TallerSmart{% endblock %}

{% block content %}
<div class="min-h-screen bg-gray-50" x-data="categoriasApp()">
    <!-- Header del módulo -->
    <div class="bg-white border-b border-gray-200 px-6 py-4">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Categorías</h1>
                <p class="text-sm text-gray-500 mt-1">Gestión de categorías de servicios del taller</p>
            </div>
            <button @click="abrirModalCrear()" 
                    class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Nueva Categoría
            </button>
        </div>
    </div>

    <!-- Filtros y búsqueda -->
    <div class="px-6 py-4 bg-white border-b border-gray-200">
        <div class="flex gap-4">
            <div class="flex-1 relative">
                <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <input type="text" x-model="busqueda" placeholder="Buscar por nombre o descripción..." 
                       class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
            </div>
            <select x-model="filtroEstado" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                <option value="">Todos los estados</option>
                <option value="1">Activos</option>
                <option value="0">Inactivos</option>
            </select>
        </div>
    </div>

    <!-- Tabla de categorías -->
    <div class="p-6">
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nombre</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Descripción</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Servicios</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <template x-for="categoria in categoriasFiltradas" :key="categoria.id">
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-medium text-gray-900" x-text="categoria.nombre"></div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="text-sm text-gray-500" x-text="categoria.descripcion || 'Sin descripción'"></div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800"
                                      x-text="categoria.servicios_count + ' servicios'"></span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium"
                                      :class="categoria.activo ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'"
                                      x-text="categoria.activo ? 'Activo' : 'Inactivo'"></span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                <div class="flex gap-2">
                                    <button @click="editarCategoria(categoria)" class="text-blue-600 hover:text-blue-900">Editar</button>
                                    <button @click="toggleEstado(categoria)" class="text-yellow-600 hover:text-yellow-900"
                                            x-text="categoria.activo ? 'Desactivar' : 'Activar'"></button>
                                    <button @click="eliminarCategoria(categoria)" class="text-red-600 hover:text-red-900">Eliminar</button>
                                </div>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
            
            <!-- Estado vacío -->
            <div x-show="categoriasFiltradas.length === 0" class="text-center py-12">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                </svg>
                <p class="mt-2 text-sm text-gray-500">No se encontraron categorías</p>
            </div>
        </div>
    </div>

    <!-- Modal Crear/Editar -->
    <div x-show="modalAbierto" class="fixed inset-0 z-50 overflow-y-auto" style="display: none;">
        <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:p-0">
            <div class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75" @click="cerrarModal()"></div>
            
            <div class="relative inline-block w-full max-w-md p-6 my-8 overflow-hidden text-left align-middle transition-all transform bg-white shadow-xl rounded-lg">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-medium text-gray-900" x-text="editando ? 'Editar Categoría' : 'Nueva Categoría'"></h3>
                    <button @click="cerrarModal()" class="text-gray-400 hover:text-gray-500">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
                
                <form @submit.prevent="guardarCategoria()">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700">Nombre *</label>
                            <input type="text" x-model="formulario.nombre" required
                                   class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700">Descripción</label>
                            <textarea x-model="formulario.descripcion" rows="3"
                                      class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500"></textarea>
                        </div>
                        
                        <div x-show="editando">
                            <label class="flex items-center">
                                <input type="checkbox" x-model="formulario.activo" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                                <span class="ml-2 text-sm text-gray-700">Activo</span>
                            </label>
                        </div>
                    </div>
                    
                    <div class="mt-6 flex justify-end gap-3">
                        <button type="button" @click="cerrarModal()" 
                                class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">
                            Cancelar
                        </button>
                        <button type="submit" 
                                class="px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700">
                            <span x-text="editando ? 'Actualizar' : 'Crear'"></span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function categoriasApp() {
    return {
        busqueda: '',
        filtroEstado: '',
        modalAbierto: false,
        editando: false,
        formulario: { id: null, nombre: '', descripcion: '', activo: true },
        categorias: [],
        
        get categoriasFiltradas() {
            return this.categorias.filter(cat => {
                const matchBusqueda = !this.busqueda || 
                    cat.nombre.toLowerCase().includes(this.busqueda.toLowerCase()) ||
                    (cat.descripcion && cat.descripcion.toLowerCase().includes(this.busqueda.toLowerCase()));
                const matchEstado = this.filtroEstado === '' || cat.activo.toString() === this.filtroEstado;
                return matchBusqueda && matchEstado;
            });
        },
        
        async init() {
            await this.cargarCategorias();
        },
        
        async cargarCategorias() {
            try {
                const response = await fetch('/api/categoria');
                if (response.ok) {
                    this.categorias = await response.json();
                }
            } catch (error) {
                console.error('Error cargando categorías:', error);
            }
        },
        
        abrirModalCrear() {
            this.editando = false;
            this.formulario = { id: null, nombre: '', descripcion: '', activo: true };
            this.modalAbierto = true;
        },
        
        editarCategoria(categoria) {
            this.editando = true;
            this.formulario = { ...categoria };
            this.modalAbierto = true;
        },
        
        cerrarModal() {
            this.modalAbierto = false;
        },
        
        async guardarCategoria() {
            try {
                const url = this.editando ? `/api/categoria/${this.formulario.id}` : '/api/categoria';
                const method = this.editando ? 'PUT' : 'POST';
                
                const response = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.formulario)
                });
                
                if (response.ok) {
                    await this.cargarCategorias();
                    this.cerrarModal();
                } else {
                    alert('Error al guardar la categoría');
                }
            } catch (error) {
                console.error('Error guardando categoría:', error);
            }
        },
        
        async toggleEstado(categoria) {
            if (!confirm(`¿${categoria.activo ? 'Desactivar' : 'Activar'} esta categoría?`)) return;
            
            try {
                const response = await fetch(`/api/categoria/${categoria.id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ activo: !categoria.activo })
                });
                
                if (response.ok) {
                    await this.cargarCategorias();
                }
            } catch (error) {
                console.error('Error cambiando estado:', error);
            }
        },
        
        async eliminarCategoria(categoria) {
            if (!confirm(`¿Eliminar permanentemente "${categoria.nombre}"?`)) return;
            
            try {
                const response = await fetch(`/api/categoria/${categoria.id}`, {
                    method: 'DELETE'
                });
                
                if (response.ok) {
                    await this.cargarCategorias();
                } else {
                    alert('Error al eliminar la categoría');
                }
            } catch (error) {
                console.error('Error eliminando categoría:', error);
            }
        }
    }
}
</script>
{% endblock %}
