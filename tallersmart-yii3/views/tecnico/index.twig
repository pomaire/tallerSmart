{% extends "@app/views/layouts/main.twig" %}

{% block title %}Técnicos - TallerSmart{% endblock %}

{% block content %}
<div class="p-6" x-data="tecnicoApp()">
    <!-- Header -->
    <div class="mb-6 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Gestión de Técnicos</h1>
            <p class="text-gray-600 mt-1">Administra el personal técnico del taller</p>
        </div>
        <button @click="abrirModal()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nuevo Técnico
        </button>
    </div>

    <!-- Filtros y Búsqueda -->
    <div class="bg-white rounded-lg shadow p-4 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Buscar</label>
                <div class="relative">
                    <input type="text" x-model="filtroBusqueda" placeholder="Nombre, RUT o especialidad..." 
                           class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                    <svg class="w-5 h-5 text-gray-400 absolute left-3 top-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Especialidad</label>
                <select x-model="filtroEspecialidad" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                    <option value="">Todas</option>
                    <option value="Motor">Motor</option>
                    <option value="Transmisión">Transmisión</option>
                    <option value="Frenos">Frenos</option>
                    <option value="Suspensión">Suspensión</option>
                    <option value="Electricidad">Electricidad</option>
                    <option value="Aire Acondicionado">Aire Acondicionado</option>
                    <option value="Diagnóstico">Diagnóstico</option>
                    <option value="Mecánica General">Mecánica General</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
                <select x-model="filtroEstado" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                    <option value="">Todos</option>
                    <option value="1">Activos</option>
                    <option value="0">Inactivos</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Tabla de Técnicos -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">RUT</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nombre</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Especialidad</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Teléfono</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <template x-for="tecnico in tecnicosFiltrados" :key="tecnico.id">
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900" x-text="formatearRUT(tecnico.rut)"></td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center mr-3">
                                        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <div class="text-sm font-medium text-gray-900" x-text="tecnico.nombre"></div>
                                        <div class="text-sm text-gray-500" x-text="tecnico.cargo"></div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-3 py-1 text-xs font-medium bg-purple-100 text-purple-800 rounded-full" x-text="tecnico.especialidad"></span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900" x-text="formatearTelefono(tecnico.telefono)"></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900" x-text="tecnico.email"></td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span :class="tecnico.activo ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'" 
                                      class="px-3 py-1 text-xs font-medium rounded-full">
                                    <span x-text="tecnico.activo ? 'Activo' : 'Inactivo'"></span>
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <button @click="editarTecnico(tecnico)" class="text-blue-600 hover:text-blue-900 mr-3" title="Editar">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </button>
                                <button @click="toggleEstado(tecnico)" class="text-yellow-600 hover:text-yellow-900 mr-3" :title="tecnico.activo ? 'Desactivar' : 'Activar'">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                                    </svg>
                                </button>
                                <button @click="eliminarTecnico(tecnico)" class="text-red-600 hover:text-red-900" title="Eliminar">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    </template>
                    <tr x-show="tecnicosFiltrados.length === 0">
                        <td colspan="7" class="px-6 py-12 text-center text-gray-500">
                            <svg class="w-12 h-12 mx-auto text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                            </svg>
                            No se encontraron técnicos
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Formulario -->
    <div x-show="modalAbierto" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50" 
         x-transition.opacity style="display: none;">
        <div class="bg-white rounded-lg shadow-xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
            <div class="p-6">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-bold text-gray-800" x-text="modoEdicion ? 'Editar Técnico' : 'Nuevo Técnico'"></h2>
                    <button @click="cerrarModal()" class="text-gray-400 hover:text-gray-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>

                <form @submit.prevent="guardarTecnico()" class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">RUT *</label>
                            <input type="text" x-model="formulario.rut" @blur="validarRUT()" 
                                   placeholder="11.111.111-1" maxlength="12"
                                   class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500"
                                   :class="{'border-red-500': errores.rut, 'border-green-500': !errores.rut && formulario.rut}" required>
                            <p x-show="errores.rut" class="text-red-500 text-xs mt-1" x-text="errores.rut"></p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Cargo</label>
                            <input type="text" x-model="formulario.cargo" placeholder="Mecánico Senior"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Nombre Completo *</label>
                        <input type="text" x-model="formulario.nombre" placeholder="Juan Pérez González"
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Especialidad *</label>
                            <select x-model="formulario.especialidad" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
                                <option value="">Seleccionar</option>
                                <option value="Motor">Motor</option>
                                <option value="Transmisión">Transmisión</option>
                                <option value="Frenos">Frenos</option>
                                <option value="Suspensión">Suspensión</option>
                                <option value="Electricidad">Electricidad</option>
                                <option value="Aire Acondicionado">Aire Acondicionado</option>
                                <option value="Diagnóstico">Diagnóstico</option>
                                <option value="Mecánica General">Mecánica General</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono *</label>
                            <input type="tel" x-model="formulario.telefono" @blur="formatearTelefonoInput()" 
                                   placeholder="+56 9 1234 5678" maxlength="15"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                        <input type="email" x-model="formulario.email" placeholder="juan.perez@tallersmart.cl"
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Fecha Ingreso</label>
                            <input type="date" x-model="formulario.fecha_ingreso"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
                            <select x-model="formulario.activo" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                                <option value="1">Activo</option>
                                <option value="0">Inactivo</option>
                            </select>
                        </div>
                    </div>

                    <div class="bg-gray-50 p-4 rounded-lg">
                        <h3 class="text-sm font-medium text-gray-700 mb-2">Certificaciones</h3>
                        <textarea x-model="formulario.certificaciones" rows="3" 
                                  placeholder="Certificaciones y cursos realizados..."
                                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"></textarea>
                    </div>

                    <div class="flex justify-end gap-3 pt-4">
                        <button type="button" @click="cerrarModal()" 
                                class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
                            Cancelar
                        </button>
                        <button type="submit" 
                                class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50"
                                :disabled="!formularioValido">
                            <span x-text="modoEdicion ? 'Actualizar' : 'Guardar'"></span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Toast Notificación -->
    <div x-show="notificacion.visible" x-transition 
         class="fixed bottom-4 right-4 px-6 py-3 rounded-lg shadow-lg text-white"
         :class="notificacion.tipo === 'success' ? 'bg-green-600' : 'bg-red-600'"
         style="display: none;">
        <span x-text="notificacion.mensaje"></span>
    </div>
</div>

<script>
function tecnicoApp() {
    return {
        modalAbierto: false,
        modoEdicion: false,
        filtroBusqueda: '',
        filtroEspecialidad: '',
        filtroEstado: '',
        errores: {},
        notificacion: { visible: false, mensaje: '', tipo: 'success' },
        
        formulario: {
            id: null,
            rut: '',
            nombre: '',
            cargo: '',
            especialidad: '',
            telefono: '',
            email: '',
            fecha_ingreso: '',
            certificaciones: '',
            activo: '1'
        },

        tecnicos: [
            { id: 1, rut: '11111111-1', nombre: 'Pedro Ramírez', cargo: 'Mecánico Senior', especialidad: 'Motor', telefono: '+56912345678', email: 'pedro.ramirez@tallersmart.cl', fecha_ingreso: '2020-01-15', certificaciones: 'Certificado en motores diesel', activo: true },
            { id: 2, rut: '22222222-2', nombre: 'Luis Morales', cargo: 'Mecánico', especialidad: 'Frenos', telefono: '+56923456789', email: 'luis.morales@tallersmart.cl', fecha_ingreso: '2021-03-20', certificaciones: 'Especialista en sistemas de frenos', activo: true },
            { id: 3, rut: '33333333-3', nombre: 'Carlos Díaz', cargo: 'Técnico', especialidad: 'Electricidad', telefono: '+56934567890', email: 'carlos.diaz@tallersmart.cl', fecha_ingreso: '2019-07-10', certificaciones: 'Certificado en electricidad automotriz', activo: true }
        ],

        get tecnicosFiltrados() {
            return this.tecnicos.filter(t => {
                const matchBusqueda = !this.filtroBusqueda || 
                    t.nombre.toLowerCase().includes(this.filtroBusqueda.toLowerCase()) ||
                    t.rut.includes(this.filtroBusqueda) ||
                    t.especialidad.toLowerCase().includes(this.filtroBusqueda.toLowerCase());
                const matchEspecialidad = !this.filtroEspecialidad || t.especialidad === this.filtroEspecialidad;
                const matchEstado = !this.filtroEstado || (this.filtroEstado === '1') === t.activo;
                return matchBusqueda && matchEspecialidad && matchEstado;
            });
        },

        get formularioValido() {
            return this.formulario.rut && this.formulario.nombre && this.formulario.especialidad && 
                   this.formulario.telefono && this.formulario.email && !this.errores.rut;
        },

        abrirModal() {
            this.modoEdicion = false;
            this.formulario = { id: null, rut: '', nombre: '', cargo: '', especialidad: '', telefono: '', email: '', fecha_ingreso: '', certificaciones: '', activo: '1' };
            this.errores = {};
            this.modalAbierto = true;
        },

        cerrarModal() {
            this.modalAbierto = false;
            this.errores = {};
        },

        editarTecnico(tecnico) {
            this.modoEdicion = true;
            this.formulario = { ...tecnico };
            this.errores = {};
            this.modalAbierto = true;
        },

        validarRUT() {
            const rut = this.formulario.rut.replace(/\./g, '').replace('-', '');
            if (rut.length < 8) {
                this.errores.rut = 'RUT inválido';
                return false;
            }
            const cuerpo = rut.slice(0, -1);
            const dv = rut.slice(-1).toUpperCase();
            let suma = 0;
            let multiplo = 2;
            for (let i = cuerpo.length - 1; i >= 0; i--) {
                suma += parseInt(cuerpo[i]) * multiplo;
                multiplo = multiplo === 7 ? 2 : multiplo + 1;
            }
            const dvEsperado = 11 - (suma % 11);
            const dvCalculado = dvEsperado === 11 ? '0' : dvEsperado === 10 ? 'K' : dvEsperado.toString();
            if (dv !== dvCalculado) {
                this.errores.rut = 'RUT inválido';
                return false;
            }
            this.errores.rut = '';
            this.formulario.rut = this.formatearRUT(rut);
            return true;
        },

        formatearRUT(rut) {
            const r = rut.replace(/\./g, '').replace('-', '');
            return r.slice(0, -1).replace(/(\d{1,2})(\d{3})(\d{3})/, '$1.$2.$3') + '-' + r.slice(-1);
        },

        formatearTelefonoInput() {
            let tel = this.formulario.telefono.replace(/[^0-9+]/g, '');
            if (tel.startsWith('569') && tel.length === 11) {
                this.formulario.telefono = '+56 ' + tel.slice(2, 3) + ' ' + tel.slice(3, 7) + ' ' + tel.slice(7);
            } else if (tel.length >= 10) {
                this.formulario.telefono = '+56 ' + tel.slice(2, 3) + ' ' + tel.slice(3, 7) + ' ' + tel.slice(7, 11);
            }
        },

        formatearTelefono(tel) {
            const t = tel.replace(/[^0-9]/g, '');
            if (t.length === 11 && t.startsWith('569')) {
                return '+56 ' + t.slice(2, 3) + ' ' + t.slice(3, 7) + ' ' + t.slice(7);
            }
            return tel;
        },

        guardarTecnico() {
            if (!this.validarRUT()) return;
            
            if (this.modoEdicion) {
                const index = this.tecnicos.findIndex(t => t.id === this.formulario.id);
                if (index !== -1) {
                    this.tecnicos[index] = { ...this.formulario, activo: this.formulario.activo === '1' };
                    this.mostrarNotificacion('Técnico actualizado correctamente', 'success');
                }
            } else {
                const nuevoId = Math.max(...this.tecnicos.map(t => t.id), 0) + 1;
                this.tecnicos.push({ ...this.formulario, id: nuevoId, activo: this.formulario.activo === '1' });
                this.mostrarNotificacion('Técnico creado correctamente', 'success');
            }
            this.cerrarModal();
        },

        toggleEstado(tecnico) {
            tecnico.activo = !tecnico.activo;
            this.mostrarNotificacion(`Técnico ${tecnico.activo ? 'activado' : 'desactivado'} correctamente`, 'success');
        },

        eliminarTecnico(tecnico) {
            if (confirm(`¿Está seguro de eliminar a ${tecnico.nombre}?`)) {
                this.tecnicos = this.tecnicos.filter(t => t.id !== tecnico.id);
                this.mostrarNotificacion('Técnico eliminado correctamente', 'success');
            }
        },

        mostrarNotificacion(mensaje, tipo) {
            this.notificacion = { visible: true, mensaje, tipo };
            setTimeout(() => this.notificacion.visible = false, 3000);
        }
    }
}
</script>
{% endblock %}
