        modulosFiltrados: [],
        
        init() {
            this.modulosFiltrados = [...this.modulos];
            this.filtrarContenido();
        },
        
        filtrarContenido() {
            if (!this.busqueda.trim()) {
                this.modulosFiltrados = [...this.modulos];
                return;
            }
            
            const termino = this.busqueda.toLowerCase();
            this.modulosFiltrados = this.modulos.filter(mod => 
                mod.titulo.toLowerCase().includes(termino) ||
                mod.descripcion.toLowerCase().includes(termino) ||
                mod.caracteristicas.some(c => c.toLowerCase().includes(termino))
            );
        },
        
        seleccionarModulo(index) {
            this.moduloActivo = index;
            document.getElementById('modulo-' + index)?.scrollIntoView({ behavior: 'smooth' });
        },
        
        obtenerColor(index) {
            const colores = [
                'bg-red-500', 'bg-orange-500', 'bg-amber-500', 'bg-yellow-500',
                'bg-lime-500', 'bg-green-500', 'bg-emerald-500', 'bg-teal-500',
                'bg-cyan-500', 'bg-sky-500', 'bg-blue-500', 'bg-indigo-500',
