{% extends "@app/views/layouts/main.twig" %}

{% block title %}Órdenes de Servicio - TallerSmart{% endblock %}

{% block content %}
<div class="container-fluid" x-data="ordenServicioApp()" x-init="init()">
    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-clipboard-list me-2"></i>Órdenes de Servicio
        </h1>
        <button @click="abrirModalCrear()" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nueva Orden
        </button>
    </div>

    <!-- Filtros y Búsqueda -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Buscar</label>
                    <input type="text" class="form-control" x-model="filtros.busqueda" 
                           placeholder="N° Orden, cliente, patente..."
                           @input.debounce.500ms="buscar()">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <select class="form-select" x-model="filtros.estado" @change="buscar()">
                        <option value="">Todos</option>
                        <option value="pendiente">Pendiente</option>
                        <option value="en_progreso">En Progreso</option>
                        <option value="espera_repuesto">Espera Repuesto</option>
                        <option value="finalizado">Finalizado</option>
                        <option value="entregado">Entregado</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Técnico</label>
                    <select class="form-select" x-model="filtros.tecnico_id" @change="buscar()">
                        <option value="">Todos</option>
                        <template for="tecnico in tecnicos">
                            <option :value="tecnico.id" x-text="tecnico.nombre"></option>
                        </template>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Desde</label>
                    <input type="date" class="form-control" x-model="filtros.fecha_desde" @change="buscar()">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Hasta</label>
                    <input type="date" class="form-control" x-model="filtros.fecha_hasta" @change="buscar()">
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button @click="resetearFiltros()" class="btn btn-outline-secondary w-100">
                        <i class="fas fa-redo"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Contenido Principal: Maestro-Detalle -->
    <div class="row">
        <!-- Lista de Órdenes (Maestro) -->
        <div class="col-lg-4 col-xl-3 mb-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h6 class="mb-0"><i class="fas fa-list me-2"></i>Órdenes</h6>
                </div>
                <div class="list-group list-group-flush" style="max-height: 70vh; overflow-y: auto;">
                    <template for="orden in ordenes">
                        <a href="#" class="list-group-item list-group-item-action"
                           :class="{ 'active': ordenSeleccionada?.id === orden.id }"
                           @click.prevent="seleccionarOrden(orden)">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1" x-text="'OS-' + orden.numero"></h6>
                                <small>
                                    <span class="badge" 
                                          :class="{
                                            'bg-warning': orden.estado === 'pendiente',
                                            'bg-info': orden.estado === 'en_progreso',
                                            'bg-secondary': orden.estado === 'espera_repuesto',
                                            'bg-success': orden.estado === 'finalizado',
                                            'bg-primary': orden.estado === 'entregado'
                                          }"
                                          x-text="formatearEstado(orden.estado)"></span>
                                </small>
                            </div>
                            <p class="mb-1 small" x-text="orden.cliente?.nombre || 'Sin cliente'"></p>
                            <small class="text-muted" x-text="orden.vehiculo?.patente || ''"></small>
                            <br>
                            <small class="text-muted" x-text="formatearFecha(orden.fecha_ingreso)"></small>
                        </a>
                    </template>
                    <div x-show="cargando" class="text-center p-3">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                    </div>
                    <div x-show="!cargando && ordenes.length === 0" class="text-center p-3 text-muted">
                        No se encontraron órdenes
                    </div>
                </div>
            </div>
        </div>

        <!-- Detalle de la Orden (Detalle) -->
        <div class="col-lg-8 col-xl-9">
            <template x-if="ordenSeleccionada">
                <div class="card">
                    <!-- Cabecera de la Orden -->
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0">
                                <i class="fas fa-clipboard me-2"></i>
                                Orden N° <span x-text="'OS-' + ordenSeleccionada.numero"></span>
                            </h5>
                            <small class="text-muted">
                                Creada: <span x-text="formatearFecha(ordenSeleccionada.fecha_ingreso)"></span>
                            </small>
                        </div>
                        <div class="btn-group">
                            <button @click="imprimirOrden()" class="btn btn-sm btn-outline-secondary" title="Imprimir">
                                <i class="fas fa-print"></i>
                            </button>
                            <button @click="editarOrden()" class="btn btn-sm btn-outline-primary" title="Editar">
                                <i class="fas fa-edit"></i>
                            </button>
                            <template x-if="ordenSeleccionada.estado !== 'entregado'">
                                <button @click="finalizarOrden()" class="btn btn-sm btn-success" title="Finalizar">
                                    <i class="fas fa-check me-1"></i> Finalizar
                                </button>
                            </template>
                        </div>
                    </div>

                    <div class="card-body">
                        <!-- Información del Cliente y Vehículo -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <h6 class="border-bottom pb-2"><i class="fas fa-user me-2"></i>Cliente</h6>
                                <p class="mb-1"><strong x-text="ordenSeleccionada.cliente?.nombre"></strong></p>
                                <p class="mb-1 small text-muted">
                                    RUT: <span x-text="ordenSeleccionada.cliente?.rut"></span>
                                </p>
                                <p class="mb-1 small text-muted">
                                    <i class="fas fa-phone me-1"></i>
                                    <span x-text="ordenSeleccionada.cliente?.telefono"></span>
                                </p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="border-bottom pb-2"><i class="fas fa-car me-2"></i>Vehículo</h6>
                                <p class="mb-1">
                                    <strong x-text="ordenSeleccionada.vehiculo?.patente"></strong>
                                    <span class="text-muted" x-text="'(' + ordenSeleccionada.vehiculo?.modelo + ')'"></span>
                                </p>
                                <p class="mb-1 small text-muted">
                                    VIN: <span x-text="ordenSeleccionada.vehiculo?.vin"></span>
                                </p>
                                <p class="mb-1 small text-muted">
                                    KM: <span x-text="formatearKM(ordenSeleccionada.kilometraje)"></span>
                                </p>
                            </div>
                        </div>

                        <!-- Técnico Asignado -->
                        <div class="alert alert-info d-flex align-items-center mb-4">
                            <i class="fas fa-user-cog fa-2x me-3"></i>
                            <div>
                                <strong>Técnico Responsable:</strong>
                                <span x-text="ordenSeleccionada.tecnico?.nombre || 'No asignado'"></span>
                                <button @click="asignarTecnico()" class="btn btn-sm btn-link ms-2">
                                    <i class="fas fa-edit"></i> Cambiar
                                </button>
                            </div>
                        </div>

                        <!-- Servicios -->
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0"><i class="fas fa-tools me-2"></i>Servicios Realizados</h6>
                                <button @click="agregarServicio()" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-plus me-1"></i> Agregar
                                </button>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Servicio</th>
                                            <th class="text-end">Precio</th>
                                            <th class="text-center">Duración</th>
                                            <th class="text-end">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <template for="detalle in ordenSeleccionada.detalles_servicios">
                                            <tr>
                                                <td x-text="detalle.servicio?.nombre"></td>
                                                <td class="text-end" x-text="formatearCLP(detalle.precio)"></td>
                                                <td class="text-center" x-text="detalle.servicio?.duracion + ' min'"></td>
                                                <td class="text-end">
                                                    <button @click="eliminarDetalle(detalle.id)" 
                                                            class="btn btn-sm btn-outline-danger">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        </template>
                                        <tr x-show="!ordenSeleccionada.detalles_servicios?.length">
                                            <td colspan="4" class="text-center text-muted py-3">
                                                No hay servicios agregados
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Repuestos -->
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0"><i class="fas fa-cogs me-2"></i>Repuestos Utilizados</h6>
                                <button @click="agregarRepuesto()" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-plus me-1"></i> Agregar
                                </button>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Repuesto</th>
                                            <th class="text-center">Cantidad</th>
                                            <th class="text-end">Precio Unit.</th>
                                            <th class="text-end">Subtotal</th>
                                            <th class="text-end">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <template for="detalle in ordenSeleccionada.detalles_repuestos">
                                            <tr>
                                                <td x-text="detalle.inventario?.nombre"></td>
                                                <td class="text-center" x-text="detalle.cantidad"></td>
                                                <td class="text-end" x-text="formatearCLP(detalle.precio_unitario)"></td>
                                                <td class="text-end" x-text="formatearCLP(detalle.subtotal)"></td>
                                                <td class="text-end">
                                                    <button @click="eliminarDetalle(detalle.id)" 
                                                            class="btn btn-sm btn-outline-danger">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        </template>
                                        <tr x-show="!ordenSeleccionada.detalles_repuestos?.length">
                                            <td colspan="5" class="text-center text-muted py-3">
                                                No hay repuestos agregados
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Totales -->
                        <div class="card bg-light">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <h6><i class="fas fa-file-alt me-2"></i>Observaciones</h6>
                                        <p class="small" x-text="ordenSeleccionada.observaciones || 'Sin observaciones'"></p>
                                        
                                        <h6 class="mt-3"><i class="fas fa-history me-2"></i>Bitácora</h6>
                                        <ul class="small text-muted list-unstyled">
                                            <template for="log in ordenSeleccionada.bitacora">
                                                <li class="mb-1">
                                                    <span x-text="formatearFecha(log.fecha)"></span>: 
                                                    <span x-text="log.descripcion"></span>
                                                </li>
                                            </template>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="text-end">
                                            <p class="mb-1">Subtotal Servicios: <strong x-text="formatearCLP(ordenSeleccionada.total_servicios)"></strong></p>
                                            <p class="mb-1">Subtotal Repuestos: <strong x-text="formatearCLP(ordenSeleccionada.total_repuestos)"></strong></p>
                                            <p class="mb-1">Descuento: <span class="text-danger" x-text="'-' + formatearCLP(ordenSeleccionada.descuento)"></span></p>
                                            <p class="mb-3">Base Imponible: <strong x-text="formatearCLP(ordenSeleccionada.base_imponible)"></strong></p>
                                            <p class="mb-1">IVA (19%): <strong x-text="formatearCLP(ordenSeleccionada.iva)"></strong></p>
                                            <hr>
                                            <h4 class="text-primary">Total: <span x-text="formatearCLP(ordenSeleccionada.total)"></span></h4>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </template>

            <template x-if="!ordenSeleccionada">
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="fas fa-clipboard-list fa-4x text-muted mb-3"></i>
                        <h5 class="text-muted">Selecciona una orden para ver los detalles</h5>
                        <p class="text-muted">O crea una nueva orden haciendo clic en "Nueva Orden"</p>
                    </div>
                </div>
            </template>
        </div>
    </div>

    <!-- Modal Nueva/Editar Orden -->
    <div class="modal fade" x-show="modales.orden" tabindex="-1" style="display: none;" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" x-text="edicion ? 'Editar Orden' : 'Nueva Orden'"></h5>
                    <button type="button" class="btn-close" @click="cerrarModalOrden()"></button>
                </div>
                <div class="modal-body">
                    <form @submit.prevent="guardarOrden()">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Cliente *</label>
                                <select class="form-select" x-model="formulario.cliente_id" required>
                                    <option value="">Seleccione...</option>
                                    <template for="cliente in clientes">
                                        <option :value="cliente.id" x-text="cliente.nombre"></option>
                                    </template>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Vehículo *</label>
                                <select class="form-select" x-model="formulario.vehiculo_id" required>
                                    <option value="">Seleccione...</option>
                                    <template for="vehiculo in vehiculos">
                                        <option :value="vehiculo.id" x-text="vehiculo.patente + ' - ' + vehiculo.modelo"></option>
                                    </template>
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Técnico</label>
                                <select class="form-select" x-model="formulario.tecnico_id">
                                    <option value="">Sin asignar</option>
                                    <template for="tecnico in tecnicos">
                                        <option :value="tecnico.id" x-text="tecnico.nombre"></option>
                                    </template>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Kilometraje</label>
                                <input type="number" class="form-control" x-model="formulario.kilometraje" placeholder="0">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Estado</label>
                                <select class="form-select" x-model="formulario.estado">
                                    <option value="pendiente">Pendiente</option>
                                    <option value="en_progreso">En Progreso</option>
                                    <option value="espera_repuesto">Espera Repuesto</option>
                                    <option value="finalizado">Finalizado</option>
                                    <option value="entregado">Entregado</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Observaciones</label>
                            <textarea class="form-control" x-model="formulario.observaciones" rows="3"></textarea>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @click="cerrarModalOrden()">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Guardar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Agregar Servicio -->
    <div class="modal fade" x-show="modales.servicio" tabindex="-1" style="display: none;">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Agregar Servicio</h5>
                    <button type="button" class="btn-close" @click="cerrarModalServicio()"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Buscar Servicio</label>
                        <input type="text" class="form-control" x-model="busquedaServicio" 
                               placeholder="Nombre del servicio..." @input="buscarServicios()">
                    </div>
                    <div class="list-group" style="max-height: 300px; overflow-y: auto;">
                        <template for="servicio in serviciosFiltrados">
                            <button type="button" class="list-group-item list-group-item-action"
                                    @click="seleccionarServicio(servicio)">
                                <div class="d-flex justify-content-between">
                                    <span x-text="servicio.nombre"></span>
                                    <span class="text-primary" x-text="formatearCLP(servicio.precio)"></span>
                                </div>
                                <small class="text-muted" x-text="servicio.duracion + ' minutos'"></small>
                            </button>
                        </template>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Agregar Repuesto -->
    <div class="modal fade" x-show="modales.repuesto" tabindex="-1" style="display: none;">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Agregar Repuesto</h5>
                    <button type="button" class="btn-close" @click="cerrarModalRepuesto()"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Buscar Repuesto</label>
                        <input type="text" class="form-control" x-model="busquedaRepuesto" 
                               placeholder="Nombre del repuesto..." @input="buscarRepuestos()">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Cantidad</label>
                        <input type="number" class="form-control" x-model="cantidadRepuesto" min="1" value="1">
                    </div>
                    <div class="list-group" style="max-height: 300px; overflow-y: auto;">
                        <template for="item in inventarioFiltrado">
                            <button type="button" class="list-group-item list-group-item-action"
                                    @click="seleccionarRepuesto(item)">
                                <div class="d-flex justify-content-between">
                                    <span x-text="item.nombre"></span>
                                    <span class="badge" :class="item.stock > 0 ? 'bg-success' : 'bg-danger'"
                                          x-text="'Stock: ' + item.stock"></span>
                                </div>
                                <small class="text-muted" x-text="formatearCLP(item.precio_venta) + ' unit.'"></small>
                            </button>
                        </template>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Asignar Técnico -->
    <div class="modal fade" x-show="modales.tecnico" tabindex="-1" style="display: none;">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Asignar Técnico</h5>
                    <button type="button" class="btn-close" @click="modales.tecnico = false"></button>
                </div>
                <div class="modal-body">
                    <select class="form-select mb-3" x-model="formulario.tecnico_id">
                        <option value="">Sin asignar</option>
                        <template for="tecnico in tecnicos">
                            <option :value="tecnico.id" x-text="tecnico.nombre"></option>
                        </template>
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @click="modales.tecnico = false">Cancelar</button>
                    <button type="button" class="btn btn-primary" @click="guardarAsignacionTecnico()">Asignar</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('ordenServicioApp', () => ({
        ordenes: [],
        ordenSeleccionada: null,
        cargando: false,
        edicion: false,
        
        // Catálogos
        clientes: [],
        vehiculos: [],
        tecnicos: [],
        servicios: [],
        inventario: [],
        
        // Filtros
        filtros: {
            busqueda: '',
            estado: '',
            tecnico_id: '',
            fecha_desde: '',
            fecha_hasta: ''
        },
        
        // Formulario
        formulario: {
            id: null,
            cliente_id: '',
            vehiculo_id: '',
            tecnico_id: '',
            kilometraje: 0,
            estado: 'pendiente',
            observaciones: ''
        },
        
        // Búsquedas en modales
        busquedaServicio: '',
        busquedaRepuesto: '',
        cantidadRepuesto: 1,
        serviciosFiltrados: [],
        inventarioFiltrado: [],
        
        // Modales
        modales: {
            orden: false,
            servicio: false,
            repuesto: false,
            tecnico: false
        },
        
        async init() {
            await Promise.all([
                this.cargarOrdenes(),
                this.cargarCatalogos()
            ]);
        },
        
        async cargarOrdenes() {
            this.cargando = true;
            try {
                const params = new URLSearchParams(this.filtros);
                const response = await fetch(`/api/orden-servicio?${params}`);
                this.ordenes = await response.json();
            } catch (error) {
                console.error('Error cargando órdenes:', error);
                alert('Error al cargar las órdenes');
            } finally {
                this.cargando = false;
            }
        },
        
        async cargarCatalogos() {
            try {
                const [clientes, vehiculos, tecnicos, servicios, inventario] = await Promise.all([
                    fetch('/api/cliente').then(r => r.json()),
                    fetch('/api/vehiculo').then(r => r.json()),
                    fetch('/api/tecnico').then(r => r.json()),
                    fetch('/api/servicio').then(r => r.json()),
                    fetch('/api/inventario').then(r => r.json())
                ]);
                this.clientes = clientes;
                this.vehiculos = vehiculos;
                this.tecnicos = tecnicos;
                this.servicios = servicios;
                this.inventario = inventario;
                this.serviciosFiltrados = servicios;
                this.inventarioFiltrado = inventario;
            } catch (error) {
                console.error('Error cargando catálogos:', error);
            }
        },
        
        buscar() {
            this.cargarOrdenes();
        },
        
        resetearFiltros() {
            this.filtros = {
                busqueda: '',
                estado: '',
                tecnico_id: '',
                fecha_desde: '',
                fecha_hasta: ''
            };
            this.cargarOrdenes();
        },
        
        seleccionarOrden(orden) {
            this.ordenSeleccionada = orden;
        },
        
        abrirModalCrear() {
            this.edicion = false;
            this.formulario = {
                id: null,
                cliente_id: '',
                vehiculo_id: '',
                tecnico_id: '',
                kilometraje: 0,
                estado: 'pendiente',
                observaciones: ''
            };
            this.modales.orden = true;
        },
        
        editarOrden() {
            if (!this.ordenSeleccionada) return;
            this.edicion = true;
            this.formulario = {
                id: this.ordenSeleccionada.id,
                cliente_id: this.ordenSeleccionada.cliente_id,
                vehiculo_id: this.ordenSeleccionada.vehiculo_id,
                tecnico_id: this.ordenSeleccionada.tecnico_id,
                kilometraje: this.ordenSeleccionada.kilometraje,
                estado: this.ordenSeleccionada.estado,
                observaciones: this.ordenSeleccionada.observaciones
            };
            this.modales.orden = true;
        },
        
        cerrarModalOrden() {
            this.modales.orden = false;
        },
        
        async guardarOrden() {
            try {
                const url = this.edicion 
                    ? `/api/orden-servicio/${this.formulario.id}`
                    : '/api/orden-servicio';
                const method = this.edicion ? 'PUT' : 'POST';
                
                const response = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.formulario)
                });
                
                if (response.ok) {
                    await this.cargarOrdenes();
                    this.cerrarModalOrden();
                    alert('Orden guardada exitosamente');
                } else {
                    const error = await response.json();
                    alert('Error: ' + (error.message || 'No se pudo guardar'));
                }
            } catch (error) {
                console.error('Error guardando orden:', error);
                alert('Error al guardar la orden');
            }
        },
        
        async finalizarOrden() {
            if (!confirm('¿Está seguro de finalizar esta orden?')) return;
            
            try {
                const response = await fetch(`/api/orden-servicio/${this.ordenSeleccionada.id}/finalizar`, {
                    method: 'POST'
                });
                
                if (response.ok) {
                    await this.cargarOrdenes();
                    await this.seleccionarOrden(this.ordenSeleccionada);
                    alert('Orden finalizada exitosamente');
                } else {
                    alert('Error al finalizar la orden');
                }
            } catch (error) {
                console.error('Error finalizando orden:', error);
                alert('Error al finalizar la orden');
            }
        },
        
        asignarTecnico() {
            this.formulario.tecnico_id = this.ordenSeleccionada?.tecnico_id;
            this.modales.tecnico = true;
        },
        
        async guardarAsignacionTecnico() {
            try {
                const response = await fetch(`/api/orden-servicio/${this.ordenSeleccionada.id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ tecnico_id: this.formulario.tecnico_id })
                });
                
                if (response.ok) {
                    await this.cargarOrdenes();
                    this.modales.tecnico = false;
                    alert('Técnico asignado exitosamente');
                }
            } catch (error) {
                console.error('Error asignando técnico:', error);
            }
        },
        
        agregarServicio() {
            if (!this.ordenSeleccionada) {
                alert('Seleccione una orden primero');
                return;
            }
            this.busquedaServicio = '';
            this.serviciosFiltrados = this.servicios;
            this.modales.servicio = true;
        },
        
        cerrarModalServicio() {
            this.modales.servicio = false;
        },
        
        buscarServicios() {
            const termo = this.busquedaServicio.toLowerCase();
            this.serviciosFiltrados = this.servicios.filter(s => 
                s.nombre.toLowerCase().includes(termo)
            );
        },
        
        seleccionarServicio(servicio) {
            // Lógica para agregar servicio a la orden
            console.log('Agregar servicio:', servicio);
            this.cerrarModalServicio();
        },
        
        agregarRepuesto() {
            if (!this.ordenSeleccionada) {
                alert('Seleccione una orden primero');
                return;
            }
            this.busquedaRepuesto = '';
            this.cantidadRepuesto = 1;
            this.inventarioFiltrado = this.inventario;
            this.modales.repuesto = true;
        },
        
        cerrarModalRepuesto() {
            this.modales.repuesto = false;
        },
        
        buscarRepuestos() {
            const termo = this.busquedaRepuesto.toLowerCase();
            this.inventarioFiltrado = this.inventario.filter(i => 
                i.nombre.toLowerCase().includes(termo)
            );
        },
        
        seleccionarRepuesto(item) {
            // Lógica para agregar repuesto a la orden
            console.log('Agregar repuesto:', item, 'Cantidad:', this.cantidadRepuesto);
            this.cerrarModalRepuesto();
        },
        
        async eliminarDetalle(id) {
            if (!confirm('¿Eliminar este ítem?')) return;
            
            try {
                const response = await fetch(`/api/orden-servicio-detalle/${id}`, {
                    method: 'DELETE'
                });
                
                if (response.ok) {
                    await this.cargarOrdenes();
                }
            } catch (error) {
                console.error('Error eliminando detalle:', error);
            }
        },
        
        imprimirOrden() {
            window.open(`/api/orden-servicio/${this.ordenSeleccionada.id}/imprimir`, '_blank');
        },
        
        // Helpers de formato
        formatearEstado(estado) {
            const estados = {
                'pendiente': 'Pendiente',
                'en_progreso': 'En Progreso',
                'espera_repuesto': 'Espera Repuesto',
                'finalizado': 'Finalizado',
                'entregado': 'Entregado'
            };
            return estados[estado] || estado;
        },
        
        formatearFecha(fecha) {
            if (!fecha) return '';
            return new Date(fecha).toLocaleDateString('es-CL', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit'
            });
        },
        
        formatearCLP(monto) {
            return new Intl.NumberFormat('es-CL', {
                style: 'currency',
                currency: 'CLP',
                minimumFractionDigits: 0
            }).format(monto || 0);
        },
        
        formatearKM(km) {
            return new Intl.NumberFormat('es-CL').format(km || 0) + ' km';
        }
    }));
});
</script>
{% endblock %}
