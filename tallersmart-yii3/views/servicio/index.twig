{% extends "@app/views/layouts/main.twig" %}

{% block title %}Servicios - TallerSmart{% endblock %}

{% block content %}
<div class="min-h-screen bg-gray-50" x-data="serviciosApp()">
    <!-- Header -->
    <div class="bg-white border-b border-gray-200 px-6 py-4">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Servicios</h1>
                <p class="text-sm text-gray-500 mt-1">Catálogo de servicios del taller</p>
            </div>
            <button @click="abrirModalCrear()" class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Nuevo Servicio
            </button>
        </div>
    </div>

    <!-- Filtros -->
    <div class="px-6 py-4 bg-white border-b border-gray-200">
        <div class="flex gap-4">
            <input type="text" x-model="busqueda" placeholder="Buscar servicio..." class="flex-1 px-4 py-2 border border-gray-300 rounded-lg">
            <select x-model="filtroCategoria" class="px-4 py-2 border border-gray-300 rounded-lg">
                <option value="">Todas las categorías</option>
                <template x-for="cat in categorias" :key="cat.id">
                    <option :value="cat.id" x-text="cat.nombre"></option>
                </template>
            </select>
        </div>
    </div>

    <!-- Tabla -->
    <div class="p-6">
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nombre</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Categoría</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Precio</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Duración</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Estado</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Acciones</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <template x-for="servicio in serviciosFiltrados" :key="servicio.id">
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4"><div class="text-sm font-medium text-gray-900" x-text="servicio.nombre"></div></td>
                            <td class="px-6 py-4"><div class="text-sm text-gray-500" x-text="servicio.categoria_nombre"></div></td>
                            <td class="px-6 py-4"><div class="text-sm font-medium text-gray-900" x-text="formatearCLP(servicio.precio)"></div></td>
                            <td class="px-6 py-4"><div class="text-sm text-gray-500" x-text="servicio.duracion_min + ' min'"></div></td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" :class="servicio.activo ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'" x-text="servicio.activo ? 'Activo' : 'Inactivo'"></span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex gap-2">
                                    <button @click="editarServicio(servicio)" class="text-blue-600 hover:text-blue-900">Editar</button>
                                    <button @click="eliminarServicio(servicio)" class="text-red-600 hover:text-red-900">Eliminar</button>
                                </div>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal -->
    <div x-show="modalAbierto" class="fixed inset-0 z-50 overflow-y-auto" style="display: none;">
        <div class="flex items-center justify-center min-h-screen px-4">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75" @click="cerrarModal()"></div>
            <div class="relative bg-white rounded-lg p-6 max-w-md w-full">
                <h3 class="text-lg font-medium mb-4" x-text="editando ? 'Editar Servicio' : 'Nuevo Servicio'"></h3>
                <form @submit.prevent="guardarServicio()" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Nombre *</label>
                        <input type="text" x-model="formulario.nombre" required class="mt-1 w-full px-3 py-2 border border-gray-300 rounded-md">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Descripción</label>
                        <textarea x-model="formulario.descripcion" rows="3" class="mt-1 w-full px-3 py-2 border border-gray-300 rounded-md"></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Categoría *</label>
                        <select x-model="formulario.categoria_id" required class="mt-1 w-full px-3 py-2 border border-gray-300 rounded-md">
                            <option value="">Seleccionar categoría</option>
                            <template x-for="cat in categorias" :key="cat.id">
                                <option :value="cat.id" x-text="cat.nombre"></option>
                            </template>
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700">Precio (CLP) *</label>
                            <input type="number" x-model="formulario.precio" required class="mt-1 w-full px-3 py-2 border border-gray-300 rounded-md">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700">Duración (min) *</label>
                            <input type="number" x-model="formulario.duracion_min" required class="mt-1 w-full px-3 py-2 border border-gray-300 rounded-md">
                        </div>
                    </div>
                    <div class="flex justify-end gap-3 mt-6">
                        <button type="button" @click="cerrarModal()" class="px-4 py-2 text-gray-700 bg-white border border-gray-300 rounded-md">Cancelar</button>
                        <button type="submit" class="px-4 py-2 text-white bg-blue-600 rounded-md" x-text="editando ? 'Actualizar' : 'Crear'"></button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function serviciosApp() {
    return {
        busqueda: '', filtroCategoria: '', modalAbierto: false, editando: false,
        formulario: { id: null, nombre: '', descripcion: '', categoria_id: '', precio: 0, duracion_min: 30, activo: true },
        servicios: [], categorias: [],
        get serviciosFiltrados() {
            return this.servicios.filter(s => {
                const matchBusqueda = !this.busqueda || s.nombre.toLowerCase().includes(this.busqueda.toLowerCase());
                const matchCategoria = !this.filtroCategoria || s.categoria_id == this.filtroCategoria;
                return matchBusqueda && matchCategoria;
            });
        },
        async init() { await Promise.all([this.cargarServicios(), this.cargarCategorias()]); },
        async cargarServicios() { try { const r = await fetch('/api/servicio'); if(r.ok) this.servicios = await r.json(); } catch(e) {} },
        async cargarCategorias() { try { const r = await fetch('/api/categoria'); if(r.ok) this.categorias = await r.json(); } catch(e) {} },
        abrirModalCrear() { this.editando = false; this.formulario = { id: null, nombre: '', descripcion: '', categoria_id: '', precio: 0, duracion_min: 30, activo: true }; this.modalAbierto = true; },
        editarServicio(s) { this.editando = true; this.formulario = {...s}; this.modalAbierto = true; },
        cerrarModal() { this.modalAbierto = false; },
        formatearCLP(v) { return new Intl.NumberFormat('es-CL', {style:'currency',currency:'CLP'}).format(v); },
        async guardarServicio() {
            try {
                const url = this.editando ? `/api/servicio/${this.formulario.id}` : '/api/servicio';
                const method = this.editando ? 'PUT' : 'POST';
                const r = await fetch(url, {method, headers:{'Content-Type':'application/json'}, body:JSON.stringify(this.formulario)});
                if(r.ok) { await this.cargarServicios(); this.cerrarModal(); }
            } catch(e) {}
        },
        async eliminarServicio(s) {
            if(!confirm(`¿Eliminar "${s.nombre}"?`)) return;
            try { const r = await fetch(`/api/servicio/${s.id}`, {method:'DELETE'}); if(r.ok) await this.cargarServicios(); } catch(e) {}
        }
    }
}
</script>
{% endblock %}
