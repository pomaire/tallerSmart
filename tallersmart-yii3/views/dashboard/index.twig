{% extends "@app/views/layouts/main.twig" %}
{% block title %}Dashboard Ejecutivo - TallerSmart{% endblock %}

{% block content %}
<div class="p-6 bg-gray-50 min-h-screen" x-data="dashboardApp()" x-init="initDashboard()">
    
    <!-- Header del Dashboard -->
    <div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Dashboard Ejecutivo</h1>
            <p class="text-gray-600 mt-1">Panel de control y métricas del taller</p>
        </div>
        
        <div class="flex items-center gap-3">
            <!-- Selector de Rango de Fechas -->
            <div class="flex items-center gap-2 bg-white rounded-lg shadow-sm border border-gray-200 p-2">
                <label class="text-sm font-medium text-gray-700">Período:</label>
                <select x-model="filtroPeriodo" @change="cargarDatos()" class="border-none text-sm focus:ring-0 cursor-pointer">
                    <option value="hoy">Hoy</option>
                    <option value="semana">Esta Semana</option>
                    <option value="mes">Este Mes</option>
                    <option value="trimestre">Últimos 3 Meses</option>
                    <option value="anio">Este Año</option>
                    <option value="personalizado">Personalizado</option>
                </select>
            </div>
            
            <button @click="exportarReporte()" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors flex items-center gap-2 shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                Exportar
            </button>
            
            <button @click="cargarDatos()" class="p-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors shadow-sm" title="Actualizar">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Loading State -->
    <div x-show="cargando" class="flex justify-center items-center py-20">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
        <span class="ml-3 text-gray-600">Cargando datos...</span>
    </div>

    <!-- Contenido Principal -->
    <div x-show="!cargando" class="space-y-6">
        
        <!-- KPIs Principales -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            
            <!-- Ingresos del Período -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-4">
                    <div class="p-3 bg-green-100 rounded-lg">
                        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <span class="text-sm font-medium" :class="tendenciaIngresos >= 0 ? 'text-green-600' : 'text-red-600'">
                        <span x-text="tendenciaIngresos >= 0 ? '↑' : '↓'"></span>
                        <span x-text="Math.abs(tendenciaIngresos) + '%'"></span>
                    </span>
                </div>
                <h3 class="text-gray-600 text-sm font-medium">Ingresos del Período</h3>
                <p class="text-3xl font-bold text-gray-900 mt-1" x-text="formatCLP(kpis.ingresos)"></p>
                <p class="text-xs text-gray-500 mt-2">vs período anterior</p>
            </div>

            <!-- Órdenes de Servicio -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-4">
                    <div class="p-3 bg-blue-100 rounded-lg">
                        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                        </svg>
                    </div>
                    <span class="text-sm font-medium text-blue-600" x-text="kpis.ordenesActivas + ' activas'"></span>
                </div>
                <h3 class="text-gray-600 text-sm font-medium">Órdenes de Servicio</h3>
                <p class="text-3xl font-bold text-gray-900 mt-1" x-text="kpis.totalOrdenes"></p>
                <p class="text-xs text-gray-500 mt-2">Total en el período</p>
            </div>

            <!-- Citas Pendientes -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-4">
                    <div class="p-3 bg-orange-100 rounded-lg">
                        <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                    <span class="text-sm font-medium" :class="kpis.citasHoy > 10 ? 'text-orange-600' : 'text-green-600'">
                        <span x-text="kpis.citasHoy + ' hoy'"></span>
                    </span>
                </div>
                <h3 class="text-gray-600 text-sm font-medium">Citas Programadas</h3>
                <p class="text-3xl font-bold text-gray-900 mt-1" x-text="kpis.totalCitas"></p>
                <p class="text-xs text-gray-500 mt-2">Próximos 7 días</p>
            </div>

            <!-- Ticket Promedio -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-4">
                    <div class="p-3 bg-purple-100 rounded-lg">
                        <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                        </svg>
                    </div>
                    <span class="text-sm font-medium" :class="tendenciaTicket >= 0 ? 'text-green-600' : 'text-red-600'">
                        <span x-text="tendenciaTicket >= 0 ? '↑' : '↓'"></span>
                        <span x-text="Math.abs(tendenciaTicket) + '%'"></span>
                    </span>
                </div>
                <h3 class="text-gray-600 text-sm font-medium">Ticket Promedio</h3>
                <p class="text-3xl font-bold text-gray-900 mt-1" x-text="formatCLP(kpis.ticketPromedio)"></p>
                <p class="text-xs text-gray-500 mt-2">Por orden de servicio</p>
            </div>
        </div>

        <!-- Gráficos y Tablas -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            
            <!-- Gráfico de Ingresos Mensuales -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-gray-900">Ingresos Mensuales</h3>
                    <span class="text-sm text-gray-500">Últimos 12 meses</span>
                </div>
                <div class="h-64 flex items-center justify-center bg-gray-50 rounded-lg border-2 border-dashed border-gray-200">
                    <div class="text-center">
                        <svg class="w-12 h-12 text-gray-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                        </svg>
                        <p class="text-gray-500 text-sm">Gráfico de barras - Integración con Chart.js</p>
                        <p class="text-xs text-gray-400 mt-1">Datos simulados para demostración</p>
                    </div>
                </div>
            </div>

            <!-- Servicios Más Solicitados -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-gray-900">Top 5 Servicios</h3>
                    <button class="text-sm text-blue-600 hover:text-blue-700 font-medium">Ver todos</button>
                </div>
                <div class="space-y-4">
                    <template x-for="(servicio, index) in serviciosTop" :key="index">
                        <div class="flex items-center gap-4">
                            <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-blue-100 text-blue-600 font-bold text-sm" x-text="index + 1"></span>
                            <div class="flex-1">
                                <h4 class="font-medium text-gray-900" x-text="servicio.nombre"></h4>
                                <div class="w-full bg-gray-200 rounded-full h-2 mt-1">
                                    <div class="bg-blue-600 h-2 rounded-full" :style="'width: ' + servicio.porcentaje + '%'"></div>
                                </div>
                            </div>
                            <span class="text-sm font-medium text-gray-600" x-text="servicio.cantidad + ' veces'"></span>
                        </div>
                    </template>
                </div>
            </div>
        </div>

        <!-- Tablas de Datos Recientes -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            
            <!-- Próximas Citas -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
                    <h3 class="text-lg font-semibold text-gray-900">Próximas Citas</h3>
                    <a href="/cita" class="text-sm text-blue-600 hover:text-blue-700 font-medium">Ver todas</a>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fecha/Hora</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cliente</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Vehículo</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <template x-for="cita in citasProximas" :key="cita.id">
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                                        <div x-text="cita.fecha"></div>
                                        <div class="text-xs text-gray-500" x-text="cita.hora"></div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900" x-text="cita.cliente"></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600" x-text="cita.vehiculo"></td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="px-2 py-1 text-xs font-medium rounded-full"
                                              :class="{
                                                  'bg-yellow-100 text-yellow-800': cita.estado === 'Pendiente',
                                                  'bg-blue-100 text-blue-800': cita.estado === 'Confirmada',
                                                  'bg-green-100 text-green-800': cita.estado === 'Completada',
                                                  'bg-red-100 text-red-800': cita.estado === 'Cancelada'
                                              }"
                                              x-text="cita.estado"></span>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Órdenes Recientes -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
                    <h3 class="text-lg font-semibold text-gray-900">Órdenes Recientes</h3>
                    <a href="/orden-servicio" class="text-sm text-blue-600 hover:text-blue-700 font-medium">Ver todas</a>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">N° Orden</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cliente</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Servicios</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <template x-for="orden in ordenesRecientes" :key="orden.id">
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-blue-600" x-text="'#' + orden.numero"></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900" x-text="orden.cliente"></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600" x-text="orden.servicios"></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900" x-text="formatCLP(orden.total)"></td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="px-2 py-1 text-xs font-medium rounded-full"
                                              :class="{
                                                  'bg-gray-100 text-gray-800': orden.estado === 'Pendiente',
                                                  'bg-blue-100 text-blue-800': orden.estado === 'En Progreso',
                                                  'bg-purple-100 text-purple-800': orden.estado === 'En Espera',
                                                  'bg-green-100 text-green-800': orden.estado === 'Finalizado',
                                                  'bg-indigo-100 text-indigo-800': orden.estado === 'Entregado'
                                              }"
                                              x-text="orden.estado"></span>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Alertas de Stock Bajo -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                    <h3 class="text-lg font-semibold text-gray-900">Alertas de Stock Bajo</h3>
                </div>
                <a href="/inventario" class="text-sm text-blue-600 hover:text-blue-700 font-medium">Gestionar inventario</a>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Producto</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Categoría</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stock Actual</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stock Mínimo</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acción</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <template x-for="item in stockBajo" :key="item.id">
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900" x-text="item.nombre"></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600" x-text="item.categoria"></td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-sm font-bold text-red-600" x-text="item.stock"></span>
                                    <span class="text-xs text-gray-500 ml-1">unidades</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600" x-text="item.stockMinimo"></td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <button @click="reponerStock(item)" class="text-sm text-blue-600 hover:text-blue-700 font-medium">Reponer</button>
                                </td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('dashboardApp', () => ({
        cargando: false,
        filtroPeriodo: 'mes',
        kpis: {
            ingresos: 0,
            totalOrdenes: 0,
            ordenesActivas: 0,
            totalCitas: 0,
            citasHoy: 0,
            ticketPromedio: 0
        },
        tendenciaIngresos: 0,
        tendenciaTicket: 0,
        serviciosTop: [],
        citasProximas: [],
        ordenesRecientes: [],
        stockBajo: [],
        
        async initDashboard() {
            await this.cargarDatos();
            // Auto-refresh cada 5 minutos
            setInterval(() => this.cargarDatos(), 300000);
        },
        
        async cargarDatos() {
            this.cargando = true;
            try {
                const [kpisRes, serviciosRes, citasRes, ordenesRes, stockRes] = await Promise.all([
                    fetch(`/api/dashboard/stats?periodo=${this.filtroPeriodo}`).then(r => r.json()),
                    fetch('/api/dashboard/servicios-top').then(r => r.json()),
                    fetch('/api/dashboard/proximas-citas').then(r => r.json()),
                    fetch('/api/dashboard/ordenes-recientes').then(r => r.json()),
                    fetch('/api/dashboard/stock-bajo').then(r => r.json())
                ]);
                
                this.kpis = kpisRes.data || kpisRes;
                this.tendenciaIngresos = kpisRes.tendenciaIngresos || 0;
                this.tendenciaTicket = kpisRes.tendenciaTicket || 0;
                this.serviciosTop = serviciosRes.data || serviciosRes;
                this.citasProximas = citasRes.data || citasRes;
                this.ordenesRecientes = ordenesRes.data || ordenesRes;
                this.stockBajo = stockRes.data || stockRes;
            } catch (error) {
                console.error('Error cargando dashboard:', error);
                // Datos mock para demostración
                this.cargarDatosMock();
            } finally {
                this.cargando = false;
            }
        },
        
        cargarDatosMock() {
            this.kpis = {
                ingresos: 15750000,
                totalOrdenes: 48,
                ordenesActivas: 12,
                totalCitas: 35,
                citasHoy: 8,
                ticketPromedio: 328125
            };
            this.tendenciaIngresos = 12.5;
            this.tendenciaTicket = 5.3;
            this.serviciosTop = [
                { nombre: 'Cambio de Aceite', cantidad: 145, porcentaje: 85 },
                { nombre: 'Revisión de Frenos', cantidad: 112, porcentaje: 72 },
                { nombre: 'Alineamiento', cantidad: 98, porcentaje: 65 },
                { nombre: 'Balanceo', cantidad: 87, porcentaje: 58 },
                { nombre: 'Mantención Mayor', cantidad: 64, porcentaje: 45 }
            ];
            this.citasProximas = [
                { id: 1, fecha: '07/05/2026', hora: '09:00', cliente: 'Juan Pérez', vehiculo: 'Toyota Yaris BBRT-34', estado: 'Confirmada' },
                { id: 2, fecha: '07/05/2026', hora: '10:30', cliente: 'María González', vehiculo: 'Suzuki Swift CGGT-45', estado: 'Pendiente' },
                { id: 3, fecha: '07/05/2026', hora: '14:00', cliente: 'Carlos Ruiz', vehiculo: 'Chevrolet Spark FHRT-67', estado: 'Confirmada' },
                { id: 4, fecha: '08/05/2026', hora: '11:00', cliente: 'Ana López', vehiculo: 'Kia Rio LLLN-89', estado: 'Pendiente' }
            ];
            this.ordenesRecientes = [
                { id: 1, numero: 'OS-2026-0145', cliente: 'Roberto Sánchez', servicios: 'Cambio aceite + Filtros', total: 85000, estado: 'En Progreso' },
                { id: 2, numero: 'OS-2026-0144', cliente: 'Pedro Ramírez', servicios: 'Revisión frenos delanteros', total: 125000, estado: 'Finalizado' },
                { id: 3, numero: 'OS-2026-0143', cliente: 'Laura Martínez', servicios: 'Mantención mayor 40k km', total: 450000, estado: 'En Espera' },
                { id: 4, numero: 'OS-2026-0142', cliente: 'Diego Fernández', servicios: 'Alineamiento + Balanceo', total: 65000, estado: 'Entregado' }
            ];
            this.stockBajo = [
                { id: 1, nombre: 'Aceite 5W30 Sintético', categoria: 'Lubricantes', stock: 3, stockMinimo: 10 },
                { id: 2, nombre: 'Filtro de Aire Toyota', categoria: 'Filtros', stock: 2, stockMinimo: 5 },
                { id: 3, nombre: 'Pastillas de Freno Delanteras', categoria: 'Frenos', stock: 4, stockMinimo: 8 }
            ];
        },
        
        formatCLP(monto) {
            return new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', minimumFractionDigits: 0 }).format(monto);
        },
        
        exportarReporte() {
            alert('Generando reporte PDF del período seleccionado...');
            // Implementar generación de PDF con jsPDF o similar
        },
        
        reponerStock(item) {
            if (confirm(`¿Desea crear una orden de compra para ${item.nombre}?`)) {
                window.location.href = `/inventario?accion=reponer&id=${item.id}`;
            }
        }
    }));
});
</script>
{% endblock %}
