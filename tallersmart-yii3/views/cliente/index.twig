{% extends "@app/views/layouts/main.twig" %}

{% block title %}Clientes - TallerSmart{% endblock %}

{% block content %}
<div class="p-6" x-data="clienteModule()">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Clientes</h1>
            <p class="text-gray-600 text-sm mt-1">Gestión de clientes del taller</p>
        </div>
        <button @click="abrirModalCrear()" 
                class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition-colors">
            <i class="fas fa-plus"></i>
            <span>Nuevo Cliente</span>
        </button>
    </div>

    <!-- Filtros y Búsqueda -->
    <div class="bg-white rounded-lg shadow p-4 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Buscar</label>
                <div class="relative">
                    <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                    <input type="text" x-model="filtroBusqueda" placeholder="RUT, nombre o email..."
                           class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
                <select x-model="filtroEstado" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                    <option value="">Todos</option>
                    <option value="1">Activos</option>
                    <option value="0">Inactivos</option>
                </select>
            </div>
            <div class="flex items-end">
                <button @click="aplicarFiltros()" class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg transition-colors">
                    <i class="fas fa-filter mr-2"></i>Filtrar
                </button>
            </div>
        </div>
    </div>

    <!-- Tabla de Clientes -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">RUT</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nombre</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Teléfono</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Vehículos</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <template x-for="cliente in clientesFiltrados" :key="cliente.id">
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="text-sm font-mono font-medium text-gray-900" x-text="formatearRUT(cliente.rut)"></span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-10 w-10 bg-blue-100 rounded-full flex items-center justify-center">
                                        <span class="text-blue-600 font-semibold" x-text="obtenerIniciales(cliente.nombre)"></span>
                                    </div>
                                    <div class="ml-4">
                                        <div class="text-sm font-medium text-gray-900" x-text="cliente.nombre"></div>
                                        <div class="text-sm text-gray-500" x-text="cliente.apellido"></div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="text-sm text-gray-900" x-text="cliente.email"></span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="text-sm text-gray-900" x-text="cliente.telefono"></span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800"
                                      x-text="cliente.vehiculos_count + ' vehículo(s)'"></span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium"
                                      :class="cliente.activo ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'"
                                      x-text="cliente.activo ? 'Activo' : 'Inactivo'"></span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <button @click="verCliente(cliente)" class="text-blue-600 hover:text-blue-900 mr-3" title="Ver">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button @click="editarCliente(cliente)" class="text-yellow-600 hover:text-yellow-900 mr-3" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button @click="eliminarCliente(cliente)" class="text-red-600 hover:text-red-900" title="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    </template>
                    <tr x-show="clientesFiltrados.length === 0">
                        <td colspan="7" class="px-6 py-12 text-center text-gray-500">
                            <i class="fas fa-users text-4xl text-gray-300 mb-4"></i>
                            <p>No se encontraron clientes</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <!-- Paginación -->
        <div class="bg-gray-50 px-6 py-3 border-t border-gray-200 flex items-center justify-between">
            <div class="text-sm text-gray-700">
                Mostrando <span x-text="clientesFiltrados.length"></span> de <span x-text="clientes.length"></span> clientes
            </div>
            <div class="flex gap-2">
                <button class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-50" disabled>
                    <i class="fas fa-chevron-left"></i>
                </button>
                <button class="px-3 py-1 border border-gray-300 rounded hover:bg-gray-100 disabled:opacity-50" disabled>
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Crear/Editar Cliente -->
    <div x-show="modalAbierto" 
         x-cloak
         class="fixed inset-0 z-50 overflow-y-auto"
         style="display: none;">
        <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:p-0">
            <div class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75" @click="cerrarModal()"></div>
            
            <div class="inline-block w-full max-w-2xl p-6 my-8 overflow-hidden text-left align-middle transition-all transform bg-white shadow-xl rounded-lg">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-gray-900" x-text="modoEdicion ? 'Editar Cliente' : 'Nuevo Cliente'"></h3>
                    <button @click="cerrarModal()" class="text-gray-400 hover:text-gray-600">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>

                <form @submit.prevent="guardarCliente()" class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">RUT <span class="text-red-500">*</span></label>
                            <input type="text" x-model="formulario.rut" @blur="validarRUT()"
                                   placeholder="11.111.111-1"
                                   class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500"
                                   :class="errores.rut ? 'border-red-500' : 'border-gray-300'" required>
                            <p x-show="errores.rut" class="text-red-500 text-xs mt-1" x-text="errores.rut"></p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Tipo Persona</label>
                            <select x-model="formulario.tipo_persona" class="w-full px-4 py-2 border border-gray-300 rounded-lg">
                                <option value="natural">Natural</option>
                                <option value="juridica">Jurídica</option>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Nombre <span class="text-red-500">*</span></label>
                            <input type="text" x-model="formulario.nombre" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Apellido</label>
                            <input type="text" x-model="formulario.apellido" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Razón Social (si es empresa)</label>
                        <input type="text" x-model="formulario.razon_social" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
                            <input type="email" x-model="formulario.email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono <span class="text-red-500">*</span></label>
                            <input type="tel" x-model="formulario.telefono" @blur="formatearTelefono()"
                                   placeholder="+56 9 1234 5678"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" required>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
                        <input type="text" x-model="formulario.direccion" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Comuna</label>
                            <input type="text" x-model="formulario.comuna" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Ciudad</label>
                            <input type="text" x-model="formulario.ciudad" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                        </div>
                    </div>

                    <div class="flex items-center gap-2">
                        <input type="checkbox" x-model="formulario.activo" id="activo" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                        <label for="activo" class="text-sm text-gray-700">Cliente activo</label>
                    </div>

                    <div class="flex justify-end gap-3 mt-6">
                        <button type="button" @click="cerrarModal()" 
                                class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
                            Cancelar
                        </button>
                        <button type="submit" 
                                class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                            <i class="fas fa-save mr-2"></i>Guardar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Ver Cliente -->
    <div x-show="modalVerAbierto" 
         x-cloak
         class="fixed inset-0 z-50 overflow-y-auto"
         style="display: none;">
        <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:p-0">
            <div class="fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75" @click="modalVerAbierto = false"></div>
            
            <div class="inline-block w-full max-w-3xl p-6 my-8 overflow-hidden text-left align-middle transition-all transform bg-white shadow-xl rounded-lg">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-gray-900">Detalle del Cliente</h3>
                    <button @click="modalVerAbierto = false" class="text-gray-400 hover:text-gray-600">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <h4 class="text-sm font-medium text-gray-500 mb-2">Información Personal</h4>
                        <div class="space-y-2">
                            <p><span class="text-gray-600">RUT:</span> <span class="font-mono font-medium" x-text="clienteSeleccionado?.rut && formatearRUT(clienteSeleccionado.rut)"></span></p>
                            <p><span class="text-gray-600">Nombre:</span> <span x-text="clienteSeleccionado?.nombre"></span></p>
                            <p><span class="text-gray-600">Apellido:</span> <span x-text="clienteSeleccionado?.apellido"></span></p>
                            <p><span class="text-gray-600">Email:</span> <span x-text="clienteSeleccionado?.email"></span></p>
                            <p><span class="text-gray-600">Teléfono:</span> <span x-text="clienteSeleccionado?.telefono"></span></p>
                        </div>
                    </div>
                    <div>
                        <h4 class="text-sm font-medium text-gray-500 mb-2">Dirección</h4>
                        <div class="space-y-2">
                            <p><span class="text-gray-600">Dirección:</span> <span x-text="clienteSeleccionado?.direccion || 'No registrada'"></span></p>
                            <p><span class="text-gray-600">Comuna:</span> <span x-text="clienteSeleccionado?.comuna || '-'"></span></p>
                            <p><span class="text-gray-600">Ciudad:</span> <span x-text="clienteSeleccionado?.ciudad || '-'"></span></p>
                        </div>
                    </div>
                </div>

                <div class="mt-6 border-t pt-4">
                    <h4 class="text-sm font-medium text-gray-500 mb-3">Vehículos Registrados</h4>
                    <div class="bg-gray-50 rounded-lg p-4">
                        <p class="text-gray-600 text-sm" x-text="(clienteSeleccionado?.vehiculos_count || 0) + ' vehículo(s) registrado(s)'"></p>
                    </div>
                </div>

                <div class="flex justify-end gap-3 mt-6">
                    <button @click="modalVerAbierto = false" 
                            class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
                        Cerrar
                    </button>
                    <button @click="editarCliente(clienteSeleccionado); modalVerAbierto = false"
                            class="px-4 py-2 bg-yellow-600 text-white rounded-lg hover:bg-yellow-700">
                        <i class="fas fa-edit mr-2"></i>Editar
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function clienteModule() {
    return {
        clientes: [],
        clientesFiltrados: [],
        filtroBusqueda: '',
        filtroEstado: '',
        modalAbierto: false,
        modalVerAbierto: false,
        modoEdicion: false,
        clienteSeleccionado: null,
        formulario: {
            id: null,
            rut: '',
            tipo_persona: 'natural',
            nombre: '',
            apellido: '',
            razon_social: '',
            email: '',
            telefono: '',
            direccion: '',
            comuna: '',
            ciudad: '',
            activo: true
        },
        errores: {},

        init() {
            this.cargarClientes();
        },

        async cargarClientes() {
            // Datos de ejemplo para desarrollo
            this.clientes = [
                { id: 1, rut: '11111111-1', nombre: 'Carlos', apellido: 'Pomaire', email: 'carlos.pomaire@email.cl', telefono: '+56 9 1234 5678', direccion: 'Av. Principal 123', comuna: 'Santiago', ciudad: 'Santiago', activo: true, vehiculos_count: 2 },
                { id: 2, rut: '22222222-2', nombre: 'María', apellido: 'González', email: 'maria.gonzalez@email.cl', telefono: '+56 9 2345 6789', direccion: 'Calle Los Alerces 456', comuna: 'Providencia', ciudad: 'Santiago', activo: true, vehiculos_count: 1 },
                { id: 3, rut: '33333333-3', nombre: 'Roberto', apellido: 'Sánchez', email: 'roberto.sanchez@email.cl', telefono: '+56 9 3456 7890', direccion: 'Pasaje El Roble 789', comuna: 'Las Condes', ciudad: 'Santiago', activo: true, vehiculos_count: 3 },
                { id: 4, rut: '44444444-4', nombre: 'Ana', apellido: 'Pérez', email: 'ana.perez@email.cl', telefono: '+56 9 4567 8901', direccion: 'Av. Italia 321', comuna: 'Ñuñoa', ciudad: 'Santiago', activo: false, vehiculos_count: 0 },
                { id: 5, rut: '55555555-5', nombre: 'Pedro', apellido: 'Ramírez', email: 'pedro.ramirez@email.cl', telefono: '+56 9 5678 9012', direccion: 'Calle Mapocho 654', comuna: 'Quilicura', ciudad: 'Santiago', activo: true, vehiculos_count: 1 }
            ];
            this.aplicarFiltros();
        },

        aplicarFiltros() {
            this.clientesFiltrados = this.clientes.filter(cliente => {
                const coincideBusqueda = !this.filtroBusqueda || 
                    cliente.rut.toLowerCase().includes(this.filtroBusqueda.toLowerCase()) ||
                    cliente.nombre.toLowerCase().includes(this.filtroBusqueda.toLowerCase()) ||
                    cliente.apellido.toLowerCase().includes(this.filtroBusqueda.toLowerCase()) ||
                    cliente.email.toLowerCase().includes(this.filtroBusqueda.toLowerCase());
                
                const coincideEstado = !this.filtroEstado || cliente.activo.toString() === this.filtroEstado;
                
                return coincideBusqueda && coincideEstado;
            });
        },

        abrirModalCrear() {
            this.modoEdicion = false;
            this.formulario = {
                id: null,
                rut: '',
                tipo_persona: 'natural',
                nombre: '',
                apellido: '',
                razon_social: '',
                email: '',
                telefono: '',
                direccion: '',
                comuna: '',
                ciudad: '',
                activo: true
            };
            this.errores = {};
            this.modalAbierto = true;
        },

        editarCliente(cliente) {
            this.modoEdicion = true;
            this.clienteSeleccionado = cliente;
            this.formulario = { ...cliente };
            this.errores = {};
            this.modalAbierto = true;
        },

        verCliente(cliente) {
            this.clienteSeleccionado = cliente;
            this.modalVerAbierto = true;
        },

        cerrarModal() {
            this.modalAbierto = false;
            this.errores = {};
        },

        validarRUT() {
            const rut = this.formulario.rut.replace(/[.-]/g, '');
            if (rut.length < 8) {
                this.errores.rut = 'RUT inválido';
                return false;
            }
            const cuerpo = rut.slice(0, -1);
            const dv = rut.slice(-1).toUpperCase();
            let suma = 0;
            let multiplo = 2;
            for (let i = cuerpo.length - 1; i >= 0; i--) {
                suma += parseInt(cuerpo[i]) * multiplo;
                multiplo = multiplo === 7 ? 2 : multiplo + 1;
            }
            const dvEsperado = 11 - (suma % 11);
            const dvCalculado = dvEsperado === 11 ? '0' : dvEsperado === 10 ? 'K' : dvEsperado.toString();
            if (dv !== dvCalculado) {
                this.errores.rut = 'RUT inválido';
                return false;
            }
            this.errores.rut = '';
            return true;
        },

        formatearTelefono() {
            let tel = this.formulario.telefono.replace(/[^0-9+]/g, '');
            if (tel.startsWith('569') && tel.length === 11) {
                this.formulario.telefono = `+56 ${tel[2]} ${tel.slice(3, 7)} ${tel.slice(7)}`;
            }
        },

        formatearRUT(rut) {
            if (!rut) return '';
            const sinFormato = rut.replace(/[.-]/g, '');
            const cuerpo = sinFormato.slice(0, -1);
            const dv = sinFormato.slice(-1);
            const cuerpoFormateado = cuerpo.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
            return `${cuerpoFormateado}-${dv}`;
        },

        obtenerIniciales(nombre) {
            if (!nombre) return '';
            return nombre.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
        },

        async guardarCliente() {
            if (!this.validarRUT()) return;
            
            if (this.modoEdicion) {
                // Actualizar cliente existente
                const index = this.clientes.findIndex(c => c.id === this.formulario.id);
                if (index !== -1) {
                    this.clientes[index] = { ...this.formulario };
                }
            } else {
                // Crear nuevo cliente
                const nuevoId = Math.max(...this.clientes.map(c => c.id), 0) + 1;
                this.clientes.push({ ...this.formulario, id: nuevoId, vehiculos_count: 0 });
            }
            
            this.aplicarFiltros();
            this.cerrarModal();
        },

        eliminarCliente(cliente) {
            if (confirm(`¿Está seguro que desea eliminar al cliente ${cliente.nombre} ${cliente.apellido}?`)) {
                this.clientes = this.clientes.filter(c => c.id !== cliente.id);
                this.aplicarFiltros();
            }
        }
    }
}
</script>
{% endblock %}
