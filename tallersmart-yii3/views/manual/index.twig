        get seccionesFiltradas() {
            if (!this.busqueda.trim()) {
                return this.secciones;
            }
            const termino = this.busqueda.toLowerCase();
            return this.secciones.filter(seccion => 
                seccion.titulo.toLowerCase().includes(termino) ||
                seccion.contenido.toLowerCase().includes(termino) ||
                (seccion.pasos && seccion.pasos.some(p => p.titulo.toLowerCase().includes(termino) || p.descripcion.toLowerCase().includes(termino)))
            );
        },
        
        filtrarContenido() {
            // Resetear scroll al primer resultado
            if (this.seccionesFiltradas.length > 0) {
                this.irASeccion(0);
            }
        },
        
        irASeccion(index) {
            this.seccionActiva = index;
            const elemento = document.getElementById('seccion-' + index);
            if (elemento) {
                elemento.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        },
        
        imprimirManual() {
            window.print();
        },
        
        descargarPDF() {
            alert('Funcionalidad de exportación a PDF en desarrollo. Pronto disponible.');
        }
    }));
