{% extends "@app/views/layouts/main.twig" %}
{% block title %}AuditLog - TallerSmart{% endblock %}
{% block content %}
<div class="audit-log-page" x-data="auditLogApp()">
    <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-3">
            <i class="fas fa-shield-alt text-purple-600"></i>Auditoría del Sistema
        </h1>
        <p class="text-sm text-gray-600 mt-2">Registro inmutable de acciones críticas</p>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-4 mb-6">
        <div class="grid grid-cols-5 gap-4">
            <select x-model="filtros.usuario_id" class="border-gray-300 rounded"><option value="">Usuario</option></select>
            <select x-model="filtros.entidad" class="border-gray-300 rounded"><option value="">Entidad</option><option value="usuario">Usuarios</option><option value="cliente">Clientes</option><option value="orden_servicio">Órdenes</option></select>
            <select x-model="filtros.accion" class="border-gray-300 rounded"><option value="">Acción</option><option value="CREATE">Crear</option><option value="UPDATE">Actualizar</option><option value="DELETE">Eliminar</option></select>
            <input type="date" x-model="filtros.fecha_desde" class="border-gray-300 rounded" placeholder="Desde">
            <input type="date" x-model="filtros.fecha_hasta" class="border-gray-300 rounded" placeholder="Hasta">
        </div>
    </div>
    <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Fecha</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Usuario</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Acción</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">Entidad</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500">IP</th>
                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500">Detalle</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                <template x-for="log in logs" :key="log.id">
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 text-sm" x-text="new Date(log.fecha_creacion).toLocaleString('es-CL')"></td>
                        <td class="px-4 py-3 text-sm" x-text="log.usuario_nombre"></td>
                        <td class="px-4 py-3"><span class="px-2 py-1 text-xs rounded" :class="{'bg-green-100 text-green-800':log.accion==='CREATE','bg-blue-100 text-blue-800':log.accion==='UPDATE','bg-red-100 text-red-800':log.accion==='DELETE'}" x-text="log.accion"></span></td>
                        <td class="px-4 py-3 text-sm"><span x-text="log.entidad_tipo"></span>#<span x-text="log.entidad_id"></span></td>
                        <td class="px-4 py-3 text-sm font-mono" x-text="log.ip"></td>
                        <td class="px-4 py-3 text-right"><button @click="verDetalle(log)" class="text-blue-600 hover:text-blue-900">Ver</button></td>
                    </tr>
                </template>
            </tbody>
        </table>
    </div>
    <div x-show="modalDetalle" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white rounded-lg p-6 w-full max-w-4xl">
            <h3 class="text-xl font-bold mb-4">Detalle de Auditoría</h3>
            <pre class="bg-gray-900 text-green-400 p-4 rounded" x-text="logSeleccionado?.cambios_json"></pre>
            <button @click="modalDetalle=false" class="mt-4 px-4 py-2 bg-gray-200 rounded">Cerrar</button>
        </div>
    </div>
</div>
<script>
document.addEventListener('alpine:init',()=>{Alpine.data('auditLogApp',()=>({logs:[],filtros:{usuario_id:'',entidad:'',accion:'',fecha_desde:'',fecha_hasta:''},pagina:1,modalDetalle:false,logSeleccionado:null,async init(){await this.cargarLogs()},async cargarLogs(){const p=new URLSearchParams({page:this.pagina,...this.filtros});const r=await fetch('/api/audit-log?'+p);const d=await r.json();this.logs=d.items||[]},verDetalle(l){this.logSeleccionado=l;this.modalDetalle=true}}))});
</script>
{% endblock %}
